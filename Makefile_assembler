# Makefile for the CPU Design FA25 assembler
# Author: Gio (Assembler Engineer)

CC      := gcc
CFLAGS  := -std=c11 -Wall -Wextra -Wpedantic -O2 -g -Iassembler
LDFLAGS :=

SRC_DIR := assembler
BUILD   := build
BIN     := assembler_bin

SOURCES := \
    $(SRC_DIR)/main.c        \
    $(SRC_DIR)/assembler.c   \
    $(SRC_DIR)/lexer.c       \
    $(SRC_DIR)/parser.c      \
    $(SRC_DIR)/symtable.c    \
    $(SRC_DIR)/encoder.c

OBJECTS := $(SOURCES:$(SRC_DIR)/%.c=$(BUILD)/%.o)

.PHONY: all assembler clean test

all: assembler

assembler: $(BIN)

$(BIN): $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) -o $@ $(LDFLAGS)

$(BUILD)/%.o: $(SRC_DIR)/%.c | $(BUILD)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD):
	mkdir -p $(BUILD)

# Build and run encoder round-trip tests
test: | $(BUILD)
	$(CC) $(CFLAGS) tests_assembler/test_encoder.c $(SRC_DIR)/encoder.c -o $(BUILD)/test_encoder
	./$(BUILD)/test_encoder

clean:
	rm -rf $(BUILD) $(BIN) *.bin
